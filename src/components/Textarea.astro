---
interface Props {
  label: string;
  name: string;
  required?: boolean;
  placeholder?: string;
  rows?: number;
  hint?: string;
}

const { label, name, required = false, placeholder, rows = 4, hint } = Astro.props;
const id = `field-${name}`;
---

<div class="flex flex-col gap-1.5">
  <label for={id} class="text-body-sm-strong text-ink">{label}{required && <span class="text-error"> *</span>}</label>
  <textarea
    id={id}
    name={name}
    required={required}
    placeholder={placeholder}
    rows={rows}
    class="focus-ring rounded-sm border border-hairline bg-canvas px-3 py-2.5 text-body-md text-ink placeholder:text-mute resize-none"
  ></textarea>
  {hint && <p class="text-caption text-mute">{hint}</p>}
</div>
