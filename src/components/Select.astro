---
interface Option {
  value: string;
  label: string;
}

interface Props {
  label: string;
  name: string;
  required?: boolean;
  options: Option[];
  placeholder?: string;
}

const { label, name, required = false, options, placeholder } = Astro.props;
const id = `field-${name}`;
---

<div class="flex flex-col gap-1.5">
  <label for={id} class="text-body-sm-strong text-ink">{label}{required && <span class="text-error"> *</span>}</label>
  <select
    id={id}
    name={name}
    required={required}
    class="focus-ring h-12 rounded-sm border border-hairline bg-canvas px-3 text-body-md text-ink"
  >
    {placeholder && <option value="">{placeholder}</option>}
    {options.map((opt) => <option value={opt.value}>{opt.label}</option>)}
  </select>
</div>
