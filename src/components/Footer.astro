---
const columns = [
  {
    heading: "For job seekers",
    links: [
      { label: "Browse jobs", href: "/finder/jobs" },
      { label: "Create a profile", href: "/signup" },
      { label: "Safety tips", href: "/safety" },
    ],
  },
  {
    heading: "For job givers",
    links: [
      { label: "Post a job", href: "/giver/post-job" },
      { label: "How verification works", href: "/safety" },
      { label: "Create an account", href: "/signup" },
    ],
  },
  {
    heading: "Company",
    links: [
      { label: "Safety & trust", href: "/safety" },
      { label: "Contact", href: "mailto:hello@helperjobshub.com" },
    ],
  },
];
---

<footer class="border-t border-hairline bg-canvas px-4 py-16 md:px-6 md:py-24">
  <div class="mx-auto grid max-w-[1400px] grid-cols-2 gap-8 md:grid-cols-4">
    <div class="col-span-2 md:col-span-1">
      <a href="/" class="flex items-center gap-2">
        <span class="grid h-7 w-7 place-items-center rounded-sm bg-ink text-sm font-semibold text-on-primary">H</span>
        <span class="text-body-sm-strong text-ink">Helper Jobs</span>
      </a>
      <p class="mt-3 max-w-xs text-body-sm text-body">
        Trusted daily-wage and household help, and honest work for the people who provide it. Free for job seekers, always.
      </p>
    </div>
    {
      columns.map((col) => (
        <div>
          <p class="font-mono text-caption uppercase tracking-wide text-mute">{col.heading}</p>
          <ul class="mt-3 flex flex-col gap-2">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="focus-ring text-body-sm text-body hover:text-ink">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
  <div class="mx-auto mt-12 max-w-[1400px] border-t border-hairline pt-6 text-caption text-mute">
    © {new Date().getFullYear()} Helper Jobs. Built to help people find honest work and reliable help.
  </div>
</footer>
