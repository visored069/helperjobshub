---
interface Props {
  label: string;
  name: string;
  type?: "text" | "email" | "password" | "tel" | "number";
  required?: boolean;
  placeholder?: string;
  value?: string;
  hint?: string;
  autocomplete?: string;
}

const { label, name, type = "text", required = false, placeholder, value, hint, autocomplete } = Astro.props;
const id = `field-${name}`;
---

<div class="flex flex-col gap-1.5">
  <label for={id} class="text-body-sm-strong text-ink">{label}{required && <span class="text-error"> *</span>}</label>
  <input
    id={id}
    name={name}
    type={type}
    required={required}
    placeholder={placeholder}
    value={value}
    autocomplete={autocomplete}
    spellcheck={type === "email" ? "false" : undefined}
    class="focus-ring h-12 rounded-sm border border-hairline bg-canvas px-3 text-body-md text-ink placeholder:text-mute"
  />
  {hint && <p class="text-caption text-mute">{hint}</p>}
</div>
