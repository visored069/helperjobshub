---
interface Props {
  variant?: "default" | "link" | "warning" | "error" | "success";
  class?: string;
}

const { variant = "default", class: className = "" } = Astro.props;

const tones: Record<string, string> = {
  default: "bg-canvas-soft text-body",
  link: "bg-link-bg-soft text-link-deep",
  warning: "bg-warning-soft text-warning-deep",
  error: "bg-error-soft text-error-deep",
  success: "bg-link-bg-soft text-link-deep",
};
---

<span class={`inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-caption ${tones[variant]} ${className}`}>
  <slot />
</span>
