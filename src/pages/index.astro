---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import CategoryCard from "../components/CategoryCard.astro";
import { categories } from "../lib/categories";
import {
  ShieldCheck,
  Star,
  IndianRupee,
  Zap,
  UserCheck,
  Ban,
} from "lucide-astro";

const trustPoints = [
  { icon: ShieldCheck, label: "Phone & ID verification" },
  { icon: Star, label: "Two-way ratings after every job" },
  { icon: IndianRupee, label: "Always free for job seekers" },
  { icon: Ban, label: "No spam, no cold calls" },
];

const seekerSteps = [
  { title: "Build a real profile, no resume", body: "Pick your skills, your experience, and your availability. No CV, no cover letter — just what you can do." },
  { title: "Browse or get matched nearby", body: "See jobs by category and location, with the pay clearly stated up front. Flip \"Available now\" so givers can find you fast." },
  { title: "Quick apply, one tap", body: "Apply instantly, no forms to refill for every job. Track every application's status in one place." },
];

const giverSteps = [
  { title: "Post a job in under a minute", body: "Pick a category, describe the work, set the pay. We show you the typical local rate so you post something fair." },
  { title: "Review verified applicants", body: "See each applicant's verification level, experience, and rating before you ever share your number." },
  { title: "Hire, and rate each other", body: "Two-way ratings after the job keep both sides honest — not just a one-star system stacked against workers." },
];

const differentiators = [
  { icon: ShieldCheck, title: "Verification-first, not an afterthought", body: "Every profile shows a real trust level — Unverified, Phone Verified, or ID Verified — visible before contact is ever shared." },
  { icon: UserCheck, title: "No resume required", body: "Job boards built for office jobs quietly exclude workers who don't have — or need — a formal resume. We don't." },
  { icon: Zap, title: "\"Available now\", not just \"applied\"", body: "Workers can signal they're ready to start today, so urgent jobs get filled fast — something classifieds can't do." },
  { icon: IndianRupee, title: "Transparent local wages", body: "Typical pay ranges are shown at posting and browsing time, so nobody has to guess — or get lowballed." },
];

const faqs = [
  {
    q: "Where can I find plumbing helper jobs?",
    a: "Browse open listings on Helper Jobs and filter by the Plumber category and your location. Every plumbing helper job shows the pay type and typical local rate up front, and you can apply in one tap without a resume.",
  },
  {
    q: "What is the best place to find HVAC helper jobs?",
    a: "Helper Jobs is built for exactly this kind of search — every HVAC helper listing comes from a verified job giver, shows real local pay before you apply, and lets you filter by location so you only see jobs you can actually get to.",
  },
  {
    q: "How do I apply to driver helper jobs?",
    a: "Create a free profile with your experience and availability, browse driver helper jobs by location and pay type, and apply with a single tap. You can track your application's status — applied, viewed, shortlisted, or hired — from your dashboard.",
  },
  {
    q: "What are the main duties of a helper?",
    a: "A helper supports a skilled worker or driver with the hands-on parts of a job — carrying materials, prepping a site or vehicle, basic assembly or cleanup, and following instructions closely while learning the trade on the job.",
  },
  {
    q: "What educational qualification is required?",
    a: "Most helper jobs don't require a formal qualification. Employers care more about reliability, willingness to learn, and physical readiness for the work than a certificate — which is why Helper Jobs profiles are built around skills and experience, not a resume.",
  },
  {
    q: "Do I need prior experience to apply?",
    a: "No. Many helper jobs are entry-level and train on the job. If you do have relevant experience, add it to your profile — some employers do prefer it for specialized trades like HVAC, welding, or machining — but it's rarely a hard requirement.",
  },
  {
    q: "What skills make a good helper?",
    a: "Reliability and punctuality top the list, followed by physical stamina, basic safety awareness, a willingness to take direction, and the ability to stay useful across several small tasks in a single shift.",
  },
  {
    q: "What is the average salary for a helper job?",
    a: "Pay varies widely by trade, location, and experience, so there's no single average that means much. Instead of guessing, every listing on Helper Jobs shows the actual pay type and amount the job giver has set before you apply.",
  },
  {
    q: "What are the typical working hours for helper jobs?",
    a: "It depends on the role — some helper jobs are one-time or short shifts, others are recurring or full-time. Job givers set this explicitly on Helper Jobs (one-time, recurring, or full-time), so you know the schedule before applying.",
  },
  {
    q: "How do I answer \"Tell me about yourself\" in a helper job interview?",
    a: "Keep it short and relevant: your current situation, any hands-on or trade-adjacent experience you have, and why you're reliable and ready to start. Tie it back to the specific role — a warehouse, driving, or trade helper job — rather than a general life story.",
  },
  {
    q: "Why do employers ask about handling multiple tasks?",
    a: "Helper roles rarely involve one task at a time — you might be prepping materials, cleaning up, and assisting the lead worker within the same hour. Employers ask this to gauge whether you can keep up with that pace without needing constant direction.",
  },
  {
    q: "How do I prepare for safety questions in an interview?",
    a: "Be ready to talk about basic PPE (gloves, boots, eye protection) for the trade you're applying to, following posted safety procedures, and reporting hazards or unsafe equipment immediately rather than working around them.",
  },
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Helper Jobs — Daily-Wage & Household Job Marketplace",
  url: "https://helperjobshub.onrender.com/",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (Web-based)",
  description:
    "A free marketplace connecting households and small businesses with verified daily-wage workers — maids, cooks, drivers, electricians, plumbers, and more. Free for job seekers, always.",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "INR",
  },
  featureList: [
    "Verified worker profiles with phone and ID verification levels",
    "No-resume job applications for daily-wage work",
    "Job posting for households and small businesses",
    "Two-way ratings after every job",
    "Available-now status for urgent hiring",
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.a,
    },
  })),
};
---

<BaseLayout
  title="Helper Jobs Near Me — HVAC, Electrician, Driver & Warehouse Helper Jobs"
  description="Find helper jobs near you — HVAC helper, electrician helper, driver helper, plumber helper, welder helper, pipefitter helper, warehouse helper, and more. Verified employers, transparent pay, no resume needed."
  keywords="helper jobs, helper jobs near me, hvac helper jobs, hvac helper jobs near me, electrician helper jobs, electrician helper jobs near me, driver helper jobs, driver helper jobs near me, plumber helper jobs, welder helper jobs, electrical helper jobs, electrical helper jobs near me, full time construction helper jobs, full time warehouse helper jobs, camp kitchen helper jobs, pipefitter helper jobs, repair helper jobs, ups driver helper jobs, manual machinist helper jobs"
  schema={[webAppSchema, faqSchema]}
>
  <!-- Hero -->
  <section class="relative overflow-hidden px-4 pb-24 pt-20 md:px-6 md:pb-32 md:pt-28">
    <div class="mesh-gradient pointer-events-none absolute inset-x-0 top-0 h-[520px] opacity-30"></div>
    <div class="relative mx-auto max-w-[840px] text-center">
      <span class="inline-flex items-center rounded-full bg-canvas-soft px-3 py-1 font-mono text-caption text-body">
        Now live · Verified helpers, always free for job seekers
      </span>
      <h1 class="mt-6 text-display-xl text-ink">
        Find trusted help. Find honest work.
      </h1>
      <p class="mx-auto mt-5 max-w-[640px] text-body-lg text-body">
        Helper Jobs connects households and small businesses with verified daily-wage workers — maids, cooks,
        drivers, electricians, and more. No resumes. No fees for the people doing the work.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <Button href="/signup" variant="primary" class="w-full sm:w-auto">I need help</Button>
        <Button href="/signup" variant="primary" class="w-full sm:w-auto">I want to work</Button>
      </div>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
        {trustPoints.map(({ icon: Icon, label }) => (
          <span class="inline-flex items-center gap-1.5 text-body-sm text-body">
            <Icon size={16} class="text-ink" aria-hidden="true" />
            {label}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Category grid -->
  <section class="px-4 py-16 md:px-6 md:py-24" id="categories">
    <div class="mx-auto max-w-[1400px]">
      <div class="mx-auto max-w-[640px] text-center">
        <h2 class="text-display-lg text-ink">Popular categories</h2>
        <p class="mt-3 text-body-md text-body">Browse visually by the kind of help you need — no typing required.</p>
      </div>
      <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
        {categories.map((category) => (
          <CategoryCard category={category} href={`/finder/jobs?category=${category.id}`} />
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-canvas-soft px-4 py-16 md:px-6 md:py-24">
    <div class="mx-auto max-w-[1400px]">
      <h2 class="text-center text-display-lg text-ink">How it works</h2>
      <div class="mt-12 grid gap-8 lg:grid-cols-2 lg:gap-12">
        <div>
          <h3 class="text-display-sm text-ink">For job seekers</h3>
          <ol class="mt-6 flex flex-col gap-6">
            {seekerSteps.map((step, i) => (
              <li class="flex gap-4">
                <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-ink text-body-sm-strong text-on-primary">{i + 1}</span>
                <div>
                  <p class="text-body-md-strong text-ink">{step.title}</p>
                  <p class="mt-1 text-body-sm text-body">{step.body}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
        <div>
          <h3 class="text-display-sm text-ink">For job givers</h3>
          <ol class="mt-6 flex flex-col gap-6">
            {giverSteps.map((step, i) => (
              <li class="flex gap-4">
                <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-ink text-body-sm-strong text-on-primary">{i + 1}</span>
                <div>
                  <p class="text-body-md-strong text-ink">{step.title}</p>
                  <p class="mt-1 text-body-sm text-body">{step.body}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Differentiators (fixed dark band, independent of light/dark theme) -->
  <section class="bg-neutral-900 px-4 py-16 text-white md:px-6 md:py-24">
    <div class="mx-auto max-w-[1400px]">
      <div class="mx-auto max-w-[640px] text-center">
        <h2 class="text-display-lg">Built differently from classifieds and corporate job boards</h2>
        <p class="mt-3 text-body-md text-neutral-300">
          OLX-style listings are unverified and spammy. Indeed and Naukri are built for office resumes. We built
          something for the people actually doing daily-wage and household work.
        </p>
      </div>
      <div class="mt-12 grid gap-4 sm:grid-cols-2">
        {differentiators.map(({ icon: Icon, title, body }) => (
          <div class="rounded-lg bg-white/5 p-6">
            <Icon size={22} class="text-cyan" aria-hidden="true" />
            <p class="mt-4 text-body-md-strong">{title}</p>
            <p class="mt-1 text-body-sm text-neutral-300">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Dual CTA -->
  <section class="px-4 py-16 md:px-6 md:py-24">
    <div class="mx-auto max-w-[1400px]">
      <div class="grid gap-6 md:grid-cols-2">
        <Card variant="marketing-lg" class="flex flex-col items-start">
          <h3 class="text-display-md text-ink">Need help around the house or business?</h3>
          <p class="mt-2 text-body-md text-body">Post a job in under a minute and start hearing from verified workers today.</p>
          <Button href="/signup" variant="primary" class="mt-6">Post a job</Button>
        </Card>
        <Card variant="marketing-lg" class="flex flex-col items-start">
          <h3 class="text-display-md text-ink">Looking for daily-wage work?</h3>
          <p class="mt-2 text-body-md text-body">Create a free profile, mark yourself available, and start applying — always free.</p>
          <Button href="/signup" variant="secondary" class="mt-6">Find work</Button>
        </Card>
      </div>
    </div>
  </section>

  <!-- SEO content: about the platform -->
  <section class="bg-canvas-soft px-4 py-16 md:px-6 md:py-24">
    <div class="mx-auto max-w-[720px]">
      <p class="text-center font-mono text-caption uppercase tracking-wide text-mute">About the platform</p>
      <h2 class="mt-3 text-center text-display-lg text-ink">Find helper jobs near you, verified from the first click</h2>

      <div class="mt-8 flex flex-col gap-5 text-body-md text-body">
        <p>Helper Jobs is a free marketplace built around one simple idea: finding real <strong class="text-ink">helper jobs</strong> shouldn't mean scrolling unverified classifieds or submitting a resume for work that never needed one. Whether you're searching for <strong class="text-ink">helper jobs near me</strong> in the trades, on the road, or in a warehouse, the platform is built around how this kind of work actually gets found, posted, and filled — fast, local, and with real verification behind every profile.</p>
        <p>For the skilled trades, Helper Jobs covers the full range of assistant and support roles that keep a job site running: <strong class="text-ink">hvac helper jobs</strong>, <strong class="text-ink">electrician helper jobs</strong>, <strong class="text-ink">plumber helper jobs</strong>, <strong class="text-ink">pipefitter helper jobs</strong>, and general <strong class="text-ink">electrical helper jobs</strong> and <strong class="text-ink">repair helper jobs</strong> all get posted the same way — a clear description, a transparent local pay range, and a real verification level on every applicant. A licensed electrician looking to fill <strong class="text-ink">electrician helper jobs near me</strong> or a contractor searching for <strong class="text-ink">hvac helper jobs near me</strong> can post a listing in under a minute and start reviewing verified applicants the same day, instead of relying on word of mouth or an unverified classifieds post.</p>
        <p>Driving and delivery work is covered just as directly. <strong class="text-ink">Driver helper jobs</strong> — including <strong class="text-ink">ups driver helper jobs</strong> and other route-assistant roles — get posted with the pay type, schedule, and location spelled out up front, so anyone searching <strong class="text-ink">driver helper jobs near me</strong> can filter straight to what actually fits their area and availability instead of digging through irrelevant listings. The same goes for skilled production roles like <strong class="text-ink">manual machinist helper jobs</strong> and <strong class="text-ink">welder helper jobs</strong>, where experience level and pay expectations matter as much as location.</p>
        <p>Helper Jobs also handles the ongoing, full-time side of helper work — <strong class="text-ink">full time construction helper jobs</strong>, <strong class="text-ink">full time warehouse helper jobs</strong>, and <strong class="text-ink">camp kitchen helper jobs</strong> can all be posted as recurring or full-time positions rather than one-off gigs, with the frequency and pay structure set clearly at posting time. A construction site or warehouse operation that needs a dependable full-time helper gets the same verification and rating system as a single day's work — reliability shows up on a profile either way.</p>
        <p>
          Posting or applying to a helper job takes the same few steps no matter the trade. Job givers set the
          category, pay type, and schedule, and can flag a listing as urgent or restrict it to verified applicants
          only when the work involves tools, vehicles, or client sites. Job seekers build one profile — skills,
          experience, and current availability — instead of rewriting a resume for every listing, then apply with
          a single tap and track exactly where each application stands: applied, viewed, shortlisted, or hired.
          That's a meaningfully faster loop than a classifieds post that disappears into a feed, or a corporate job
          board that assumes a formal work history most helper roles simply don't require.
        </p>
        <p>Every search on Helper Jobs is built around location, so <strong class="text-ink">electrical helper jobs near me</strong> and <strong class="text-ink">helper jobs near me</strong> return listings that are actually reachable, not just relevant by category. And because every profile — worker or job giver — carries a real verification level and picks up two-way ratings after every job, trust builds on the platform itself instead of resetting with every new listing. Whatever kind of helper job you're hiring for or looking for, Helper Jobs gives you a faster, more transparent way to connect: post a job or build a profile, and see verified matches within minutes.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="px-4 py-16 md:px-6 md:py-24">
    <div class="mx-auto max-w-[1100px]">
      <p class="text-center font-mono text-caption uppercase tracking-wide text-mute">FAQ</p>
      <h2 class="mt-3 text-center text-display-lg text-ink">Common questions</h2>
      <p class="mx-auto mt-3 max-w-[560px] text-center text-body-md text-body">
        Everything people ask before hiring help or applying for daily-wage work on Helper Jobs.
      </p>

      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {faqs.map((item) => (
          <div class="rounded-md border border-hairline bg-canvas p-5">
            <h3 class="text-body-md-strong text-ink">{item.q}</h3>
            <p class="mt-2 text-body-sm text-body">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Company -->
  <section class="bg-canvas-soft px-4 py-16 md:px-6 md:py-24">
    <div class="mx-auto max-w-[1400px]">
      <h2 class="text-center text-display-lg text-ink">Get to know Helper Jobs</h2>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { href: "/about", title: "About us", body: "Why we built a verification-first job marketplace." },
          { href: "/safety", title: "Safety & trust", body: "How verification, ratings, and reporting work." },
          { href: "/contact", title: "Contact us", body: "Support, feedback, and safety reports." },
          { href: "/privacy", title: "Privacy policy", body: "How we handle your information." },
        ].map((item) => (
          <a href={item.href} class="group rounded-md border border-hairline bg-canvas p-6 transition-colors hover:border-hairline-strong">
            <h3 class="text-body-md-strong text-ink group-hover:text-link">{item.title}</h3>
            <p class="mt-1 text-body-sm text-body">{item.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
