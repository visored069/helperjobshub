---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
---

<BaseLayout title="Page not found">
  <section class="mx-auto flex max-w-[560px] flex-col items-center px-4 py-24 text-center">
    <p class="font-mono text-caption text-mute">404</p>
    <h1 class="mt-3 text-display-lg text-ink">This page doesn't exist</h1>
    <p class="mt-3 text-body-md text-body">The page you're looking for may have moved or been removed.</p>
    <div class="mt-8 flex gap-3">
      <Button href="/" variant="primary">Go home</Button>
      <Button href="/finder/jobs" variant="secondary">Browse jobs</Button>
    </div>
  </section>
</BaseLayout>
