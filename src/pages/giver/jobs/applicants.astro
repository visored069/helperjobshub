---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Applicants">
  <section class="mx-auto max-w-[800px] px-4 py-12 md:px-6 md:py-16">
    <a href="/giver/jobs" class="focus-ring text-body-sm text-body hover:text-ink">&larr; Back to my listings</a>
    <h1 id="job-title" class="mt-4 text-display-lg text-ink"></h1>
    <p id="job-meta" class="mt-2 text-body-md text-body"></p>

    <div id="not-found" class="hidden mt-8 text-body-md text-body">This job couldn't be found.</div>
    <div id="applicants-list" class="mt-8 flex flex-col gap-3"></div>
  </section>
</BaseLayout>

<script>
  import { requireSession, getJob, getApplicantsForJob, setApplicationStatus } from "../../../lib/api-client";
  import { getCategory } from "../../../lib/categories";
  import type { ApplicationStatus } from "../../../lib/types";

  const session = await requireSession("giver");
  if (session) {
    const params = new URLSearchParams(window.location.search);
    const jobId = params.get("id") ?? "";
    const job = jobId ? await getJob(jobId) : undefined;

    if (!job) {
      document.getElementById("not-found")!.classList.remove("hidden");
    } else {
      const category = getCategory(job.categoryId);
      document.getElementById("job-title")!.textContent = job.title;
      document.getElementById("job-meta")!.textContent = `${category?.label ?? ""} · ${job.location}`;

      const list = document.getElementById("applicants-list") as HTMLDivElement;
      const applicants = await getApplicantsForJob(job.id);

      const verificationLabel = { unverified: "Unverified", phone: "Phone Verified", id: "ID Verified" };
      const verificationTone = { unverified: "bg-warning-soft text-warning-deep", phone: "bg-canvas-soft text-body", id: "bg-link-bg-soft text-link-deep" };

      for (const applicant of applicants) {
        const card = document.createElement("div");
        card.className = "rounded-md border border-hairline bg-canvas p-5";

        const top = document.createElement("div");
        top.className = "flex flex-wrap items-start justify-between gap-3";

        const left = document.createElement("div");
        const name = document.createElement("p");
        name.className = "text-body-md-strong text-ink";
        name.textContent = applicant.name;
        const meta = document.createElement("p");
        meta.className = "mt-1 flex items-center gap-3 text-body-sm text-body";
        meta.innerHTML = `<span class="inline-flex items-center gap-1"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-warning" aria-hidden="true"><path d="M12 2l2.9 6.26L22 9.27l-5 4.87L18.2 21 12 17.77 5.8 21 7 14.14 2 9.27l7.1-1.01L12 2z"/></svg>${applicant.rating.toFixed(1)}</span> · ${applicant.experienceYears} yrs experience · Applied ${applicant.appliedAt}`;
        left.append(name, meta);

        const badge = document.createElement("span");
        badge.className = `shrink-0 rounded-full px-2.5 py-1 text-caption font-medium ${verificationTone[applicant.verification]}`;
        badge.textContent = verificationLabel[applicant.verification];

        top.append(left, badge);

        const actions = document.createElement("div");
        actions.className = "mt-4 flex items-center gap-2 border-t border-hairline pt-4";

        const decisionLabel = document.createElement("span");
        decisionLabel.className = "text-body-sm text-body";

        function refreshLabel(status: ApplicationStatus) {
          decisionLabel.textContent =
            status === "shortlisted" ? "Shortlisted" : status === "declined" ? "Declined" : status === "hired" ? "Hired" : "No decision yet";
        }

        const shortlistBtn = document.createElement("button");
        shortlistBtn.type = "button";
        shortlistBtn.className = "focus-ring rounded-sm bg-ink px-3 py-1.5 text-body-sm-strong text-on-primary hover:bg-ink-hover";
        shortlistBtn.textContent = "Shortlist";
        shortlistBtn.addEventListener("click", async () => {
          await setApplicationStatus(applicant.applicationId, "shortlisted");
          refreshLabel("shortlisted");
        });

        const declineBtn = document.createElement("button");
        declineBtn.type = "button";
        declineBtn.className = "focus-ring rounded-sm border border-hairline px-3 py-1.5 text-body-sm text-ink hover:bg-canvas-soft-2";
        declineBtn.textContent = "Decline";
        declineBtn.addEventListener("click", async () => {
          await setApplicationStatus(applicant.applicationId, "declined");
          refreshLabel("declined");
        });

        refreshLabel(applicant.status);

        actions.append(shortlistBtn, declineBtn, decisionLabel);
        card.append(top, actions);
        list.appendChild(card);
      }
    }
  }
</script>
