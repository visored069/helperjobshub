---
import BaseLayout from "../layouts/BaseLayout.astro";
import { HardHat, Search } from "lucide-astro";
---

<BaseLayout title="Choose how you'll use Helper Jobs">
  <section class="mx-auto flex max-w-[880px] flex-col items-center px-4 py-16 text-center md:py-24">
    <h1 class="text-display-lg text-ink">How would you like to use Helper Jobs?</h1>
    <p class="mt-3 max-w-[520px] text-body-md text-body">
      You can switch anytime — one account can both hire help and look for work.
    </p>

    <div class="mt-10 grid w-full gap-6 sm:grid-cols-2">
      <button type="button" data-role="giver" class="focus-ring group flex flex-col items-center gap-4 rounded-lg border border-hairline bg-canvas p-10 text-center shadow-card transition-colors hover:border-hairline-strong hover:bg-canvas-soft-2">
        <span class="grid h-14 w-14 place-items-center rounded-full bg-canvas-soft text-ink">
          <HardHat size={28} aria-hidden="true" />
        </span>
        <span class="text-display-sm text-ink">I'm hiring for help</span>
        <span class="text-body-sm text-body">Post jobs and find verified workers for household or business work.</span>
      </button>

      <button type="button" data-role="finder" class="focus-ring group flex flex-col items-center gap-4 rounded-lg border border-hairline bg-canvas p-10 text-center shadow-card transition-colors hover:border-hairline-strong hover:bg-canvas-soft-2">
        <span class="grid h-14 w-14 place-items-center rounded-full bg-canvas-soft text-ink">
          <Search size={28} aria-hidden="true" />
        </span>
        <span class="text-display-sm text-ink">I'm looking for work</span>
        <span class="text-body-sm text-body">Build a profile, browse jobs near you, and apply in one tap.</span>
      </button>
    </div>
  </section>
</BaseLayout>

<script>
  import { requireSession, setActiveRole } from "../lib/store";
  import type { Role } from "../lib/types";

  requireSession();

  for (const btn of document.querySelectorAll<HTMLButtonElement>("[data-role]")) {
    btn.addEventListener("click", () => {
      const role = btn.dataset.role as Role;
      setActiveRole(role);
      window.location.href = `/${role}/dashboard`;
    });
  }
</script>
