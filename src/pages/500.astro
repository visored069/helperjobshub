---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
---

<BaseLayout title="Something went wrong" noindex>
  <section class="mx-auto flex max-w-[560px] flex-col items-center px-4 py-24 text-center">
    <p class="font-mono text-caption text-mute">500</p>
    <h1 class="mt-3 text-display-lg text-ink">Something went wrong on our end</h1>
    <p class="mt-3 text-body-md text-body">This wasn't your fault. Try again in a moment, or head back home.</p>
    <div class="mt-8 flex gap-3">
      <Button href="/" variant="primary">Go home</Button>
      <Button href="/contact" variant="secondary">Contact us</Button>
    </div>
  </section>
</BaseLayout>
