---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import Textarea from "../../components/Textarea.astro";
import Select from "../../components/Select.astro";
import Button from "../../components/Button.astro";
import CategoryIcon from "../../components/CategoryIcon.astro";
import { categories } from "../../lib/categories";
import { Star } from "lucide-astro";

const experienceOptions = [
  { value: "0", label: "Just starting out" },
  { value: "1", label: "1–2 years" },
  { value: "3", label: "3–5 years" },
  { value: "6", label: "6+ years" },
];
---

<BaseLayout title="My profile">
  <section class="mx-auto max-w-[720px] px-4 py-12 md:px-6 md:py-16">
    <h1 class="text-display-lg text-ink">My profile</h1>
    <p class="mt-2 text-body-md text-body">No resume needed — just your skills, experience, and availability.</p>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <span id="verification-badge" class="rounded-full bg-canvas-soft px-3 py-1 text-body-sm-strong text-body"></span>
      <span id="rating-display" class="inline-flex items-center gap-1 text-body-sm text-body">
        <Star size={14} class="text-warning" aria-hidden="true" />
        <span id="rating-text">No ratings yet</span>
      </span>
    </div>
    <div class="mt-3 flex gap-2">
      <button id="verify-phone-btn" type="button" class="focus-ring rounded-sm border border-hairline px-3 py-1.5 text-body-sm text-ink hover:bg-canvas-soft-2">Verify phone (demo)</button>
      <button id="verify-id-btn" type="button" class="focus-ring rounded-sm border border-hairline px-3 py-1.5 text-body-sm text-ink hover:bg-canvas-soft-2">Verify ID (demo)</button>
    </div>

    <Card variant="soft" class="mt-8">
      <form id="profile-form" class="flex flex-col gap-6">
        <label class="flex cursor-pointer items-center justify-between gap-4 rounded-md bg-canvas p-4">
          <span>
            <span class="block text-body-md-strong text-ink">Available now</span>
            <span class="block text-body-sm text-body">Let job givers know you're ready to start today.</span>
          </span>
          <span class="relative inline-flex h-6 w-11 shrink-0 items-center rounded-full bg-hairline-strong transition-colors has-[:checked]:bg-ink">
            <input type="checkbox" id="field-availableNow" name="availableNow" class="peer sr-only" />
            <span class="inline-block h-4 w-4 translate-x-1 rounded-full bg-white transition-transform peer-checked:translate-x-6"></span>
          </span>
        </label>

        <fieldset>
          <legend class="text-body-sm-strong text-ink">Your skills</legend>
          <p class="mt-1 text-caption text-mute">Select every category you can work in.</p>
          <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-3">
            {categories.map((cat) => (
              <label class="focus-ring flex cursor-pointer items-center gap-2 rounded-sm border border-hairline bg-canvas px-3 py-2 text-body-sm text-ink has-[:checked]:border-ink has-[:checked]:bg-canvas-soft-2">
                <input type="checkbox" name="skills" value={cat.id} class="h-4 w-4 rounded border-hairline-strong" />
                <CategoryIcon name={cat.icon} size={16} class="text-body" />
                {cat.label}
              </label>
            ))}
          </div>
        </fieldset>

        <Select label="Experience" name="experienceYears" options={experienceOptions} />
        <Textarea label="A little about you" name="bio" placeholder="e.g. Reliable, punctual, 3 years cooking for two families in Koramangala." rows={3} />

        <p id="profile-saved" class="hidden text-body-sm text-link">Profile saved.</p>
        <Button type="submit" variant="primary" class="w-full sm:w-auto">Save profile</Button>
      </form>
    </Card>
  </section>
</BaseLayout>

<script>
  import { requireSession, getWorkerProfile, saveWorkerProfile } from "../../lib/store";

  const session = requireSession("finder");
  if (session) {
    const profile = getWorkerProfile();
    const form = document.getElementById("profile-form") as HTMLFormElement;
    const badge = document.getElementById("verification-badge") as HTMLSpanElement;
    const ratingText = document.getElementById("rating-text") as HTMLSpanElement;

    function reflectVerification() {
      const labels = { unverified: "Unverified", phone: "Phone Verified", id: "ID Verified" };
      badge.textContent = labels[profile.verification];
    }
    function reflectRating() {
      ratingText.textContent = profile.ratingCount > 0 ? `${profile.rating.toFixed(1)} (${profile.ratingCount} ratings)` : "No ratings yet";
    }
    reflectVerification();
    reflectRating();

    (form.elements.namedItem("availableNow") as HTMLInputElement).checked = profile.availableNow;
    (form.elements.namedItem("experienceYears") as HTMLSelectElement).value = String(profile.experienceYears);
    (form.elements.namedItem("bio") as HTMLTextAreaElement).value = profile.bio;
    for (const box of form.querySelectorAll<HTMLInputElement>('input[name="skills"]')) {
      box.checked = profile.skills.includes(box.value);
    }

    document.getElementById("verify-phone-btn")!.addEventListener("click", () => {
      if (profile.verification === "unverified") profile.verification = "phone";
      saveWorkerProfile(profile);
      reflectVerification();
    });
    document.getElementById("verify-id-btn")!.addEventListener("click", () => {
      profile.verification = "id";
      saveWorkerProfile(profile);
      reflectVerification();
    });

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const updated = {
        ...profile,
        name: session.name,
        availableNow: data.get("availableNow") === "on",
        experienceYears: Number(data.get("experienceYears") ?? 0),
        bio: String(data.get("bio") ?? ""),
        skills: data.getAll("skills").map(String),
      };
      saveWorkerProfile(updated);
      document.getElementById("profile-saved")!.classList.remove("hidden");
    });
  }
</script>
