---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Button from "../../../components/Button.astro";
import { ShieldAlert } from "lucide-astro";
---

<BaseLayout title="Job details">
  <section class="mx-auto max-w-[720px] px-4 py-12 md:px-6 md:py-16">
    <a href="/finder/jobs" class="focus-ring text-body-sm text-body hover:text-ink">&larr; Back to browse jobs</a>

    <div id="not-found" class="hidden mt-8 text-body-md text-body">
      This job couldn't be found — it may have been closed or removed.
    </div>

    <div id="job-detail" class="mt-6">
      <div class="flex items-center gap-2">
        <span id="job-category" class="text-caption text-mute"></span>
        <span id="job-urgent" class="hidden rounded-full bg-warning-soft px-2 py-0.5 text-caption text-warning-deep">Urgent</span>
        <span id="job-verified" class="hidden rounded-full bg-link-bg-soft px-2 py-0.5 text-caption text-link-deep">Verified workers only</span>
      </div>
      <h1 id="job-title" class="mt-3 text-display-lg text-ink"></h1>
      <p id="job-meta" class="mt-2 text-body-sm text-body"></p>

      <p id="job-description" class="mt-6 text-body-md text-body"></p>

      <dl class="mt-6 grid grid-cols-2 gap-4 rounded-md border border-hairline bg-canvas p-5">
        <div>
          <dt class="text-caption text-mute">Pay</dt>
          <dd id="job-pay" class="mt-1 text-body-md-strong text-ink"></dd>
        </div>
        <div>
          <dt class="text-caption text-mute">Frequency</dt>
          <dd id="job-frequency" class="mt-1 text-body-md-strong text-ink"></dd>
        </div>
        <div>
          <dt class="text-caption text-mute">Location</dt>
          <dd id="job-location" class="mt-1 text-body-md-strong text-ink"></dd>
        </div>
        <div>
          <dt class="text-caption text-mute">Posted by</dt>
          <dd id="job-postedby" class="mt-1 text-body-md-strong text-ink"></dd>
        </div>
      </dl>

      <div class="mt-6 flex items-start gap-3 rounded-md bg-canvas-soft p-4">
        <ShieldAlert size={18} class="mt-0.5 shrink-0 text-warning-deep" aria-hidden="true" />
        <p class="text-body-sm text-body">
          Never pay money upfront to apply or to secure a job. Meet in a safe location for the first visit when
          possible, and verify identity before sharing your home address. Read our <a href="/safety" class="text-link hover:underline">full safety guide</a>.
        </p>
      </div>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button id="apply-btn" variant="primary" class="w-full sm:w-auto">Quick Apply</Button>
      </div>
      <p id="apply-status" class="mt-3 text-body-sm text-body"></p>
    </div>
  </section>
</BaseLayout>

<script>
  import { getJob, getSession, applyToJob, hasApplied } from "../../../lib/store";
  import { getCategory } from "../../../lib/categories";

  const params = new URLSearchParams(window.location.search);
  const jobId = params.get("id") ?? "";
  const job = jobId ? getJob(jobId) : undefined;

  const detailEl = document.getElementById("job-detail") as HTMLDivElement;
  const notFoundEl = document.getElementById("not-found") as HTMLDivElement;

  if (!job) {
    detailEl.classList.add("hidden");
    notFoundEl.classList.remove("hidden");
  } else {
    const category = getCategory(job.categoryId);
    document.getElementById("job-category")!.textContent = category?.label ?? "";
    if (job.urgent) document.getElementById("job-urgent")!.classList.remove("hidden");
    if (job.verifiedOnly) document.getElementById("job-verified")!.classList.remove("hidden");
    document.getElementById("job-title")!.textContent = job.title;
    document.getElementById("job-meta")!.textContent = `Posted ${job.postedAt}`;
    document.getElementById("job-description")!.textContent = job.description;
    document.getElementById("job-pay")!.textContent = job.payAmount;
    document.getElementById("job-frequency")!.textContent = job.frequency.replace("-", " ");
    document.getElementById("job-location")!.textContent = job.location;
    document.getElementById("job-postedby")!.textContent = job.postedBy;

    const applyBtn = document.getElementById("apply-btn") as HTMLButtonElement;
    const applyStatus = document.getElementById("apply-status") as HTMLParagraphElement;

    function reflectApplyState() {
      const session = getSession();
      if (session && hasApplied(job!.id, session.email)) {
        applyBtn.textContent = "Applied";
        applyBtn.setAttribute("disabled", "true");
        applyBtn.classList.add("opacity-60", "pointer-events-none");
        applyStatus.textContent = "You've already applied to this job — track it from your Applications page.";
      }
    }
    reflectApplyState();

    applyBtn.addEventListener("click", () => {
      const session = getSession();
      if (!session) {
        window.location.href = `/login?next=/finder/jobs/view?id=${job!.id}`;
        return;
      }
      applyToJob(job!.id, session.email);
      reflectApplyState();
    });
  }
</script>
